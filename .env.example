# Runtime
NODE_VERSION=22.22.0
PORT=10000
PUBLIC_BASE_URL=https://YOUR-APP.onrender.com
OAUTH_COOKIE_SECRET=CHANGE_ME_LONG_RANDOM_STRING
MCP_REQUIRE_APPROVAL=never

# OpenAI
# Recommended on Render: use Secret File OPENAI_API_SECRET instead of this env var.
OPENAI_MODEL=gpt-4.1-mini
OPENAI_STORE=false
# OPENAI_API_KEY=sk-proj-...

# Google OAuth — preferred names
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://YOUR-APP.onrender.com/api/oauth/callback/google

# Google OAuth — optional scope override. Leave commented unless debugging.
# GOOGLE_SCOPES=openid email profile https://www.googleapis.com/auth/gmail.readonly https://www.googleapis.com/auth/drive.readonly https://www.googleapis.com/auth/calendar.readonly

# Google OAuth — accepted aliases, use only if you prefer these names instead of the preferred ones
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URI=https://YOUR-APP.onrender.com/api/oauth/callback/google

# Microsoft OAuth — preferred names
# For personal Outlook/Hotmail/Live accounts, create the Entra app as
# "Personal Microsoft accounts only" or "Any org directory + personal accounts".
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=https://YOUR-APP.onrender.com/api/oauth/callback/microsoft

# Microsoft personal-account defaults. Keep these for Hotmail/Outlook/Live.
MICROSOFT_TENANT=consumers
MICROSOFT_SCOPES=openid profile email offline_access https://graph.microsoft.com/User.Read https://graph.microsoft.com/Mail.Read https://graph.microsoft.com/Files.Read.All https://graph.microsoft.com/Calendars.Read

# Microsoft work/school-only scopes. Do NOT add these until the personal flow works.
# MICROSOFT_SCOPES=openid profile email offline_access https://graph.microsoft.com/User.Read https://graph.microsoft.com/Mail.Read https://graph.microsoft.com/Files.Read.All https://graph.microsoft.com/Calendars.Read https://graph.microsoft.com/Sites.Read.All https://graph.microsoft.com/Team.ReadBasic.All

# Microsoft OAuth — accepted aliases, use only if you prefer these names instead of the preferred ones
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=
# AZURE_REDIRECT_URI=https://YOUR-APP.onrender.com/api/oauth/callback/microsoft
# MS_CLIENT_ID=
# MS_CLIENT_SECRET=
# MS_REDIRECT_URI=https://YOUR-APP.onrender.com/api/oauth/callback/microsoft

# Do not add provider-specific cookie secrets. The backend uses one global cookie secret:
# OAUTH_COOKIE_SECRET=...
# GOOGLE_COOKIE_SECRET=     # unused
# MICROSOFT_COOKIE_SECRET=  # unused
