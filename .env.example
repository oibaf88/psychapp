# Runtime
NODE_VERSION=22.22.0
PORT=10000
PUBLIC_BASE_URL=https://psychapp.bfab.io
OAUTH_COOKIE_SECRET=CHANGE_ME_LONG_RANDOM_STRING
MCP_REQUIRE_APPROVAL=never

# OpenAI
# Recommended on Render: use Secret File OPENAI_API_SECRET instead of this env var.
OPENAI_MODEL=gpt-4.1-mini
OPENAI_STORE=false
# OPENAI_API_KEY=YOUR_OPENAI_API_KEY
# MOCK_AI=true lets you smoke-test OAuth/UI without spending OpenAI API credits.
# Keep MOCK_AI unset or false in real analysis.
# MOCK_AI=false

# Important: do not set custom OAuth scopes unless you know exactly what you are doing.
# The backend ignores GOOGLE_SCOPES and MICROSOFT_SCOPES unless this is explicitly true.
ALLOW_CUSTOM_OAUTH_SCOPES=false

# Google OAuth — preferred names
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://psychapp.bfab.io/api/oauth/callback/google

# Google OAuth — accepted aliases, use only if you prefer these names instead of the preferred ones
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URI=https://psychapp.bfab.io/api/oauth/callback/google

# Microsoft OAuth — preferred names
# For personal Outlook/Hotmail/Live accounts, create the Entra app as
# "Personal Microsoft accounts only" or "Any org directory + personal accounts".
MICROSOFT_TENANT=consumers
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=https://psychapp.bfab.io/api/oauth/callback/microsoft

# Leave MICROSOFT_SCOPES unset on Render unless ALLOW_CUSTOM_OAUTH_SCOPES=true.
# Safe default used by backend:
# openid profile email offline_access User.Read Mail.Read Files.Read.All Calendars.Read

# Microsoft OAuth — accepted aliases, use only if you prefer these names instead of the preferred ones
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=
# AZURE_REDIRECT_URI=https://psychapp.bfab.io/api/oauth/callback/microsoft
# MS_CLIENT_ID=
# MS_CLIENT_SECRET=
# MS_REDIRECT_URI=https://psychapp.bfab.io/api/oauth/callback/microsoft

# Do not add provider-specific cookie secrets. The backend uses one global cookie secret:
# OAUTH_COOKIE_SECRET=...
# GOOGLE_COOKIE_SECRET=     # unused
# MICROSOFT_COOKIE_SECRET=  # unused
