# Runtime
NODE_VERSION=22.22.0
PORT=10000
PUBLIC_BASE_URL=https://YOUR-APP.onrender.com
OAUTH_COOKIE_SECRET=CHANGE_ME_LONG_RANDOM_STRING
MCP_REQUIRE_APPROVAL=never

# OpenAI
# Recommended on Render: use Secret File OPENAI_API_SECRET instead of this env var.
OPENAI_MODEL=gpt-4.1-mini
OPENAI_STORE=false
# OPENAI_API_KEY=sk-proj-...

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://YOUR-APP.onrender.com/api/oauth/callback/google

# Microsoft OAuth
# For personal Outlook/Hotmail/Live accounts, create the Entra app as
# "Personal Microsoft accounts only" or "Any org directory + personal accounts".
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=https://YOUR-APP.onrender.com/api/oauth/callback/microsoft
