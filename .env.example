APP_BASE_PATH=/psychapp
PUBLIC_BASE_URL=http://localhost:10000/psychapp
PORT=10000

# OpenAI server-side only
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
OPENAI_STORE=false

# OAuth encryption. Use a long random value in production.
OAUTH_COOKIE_SECRET=

# Google OAuth app
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Microsoft OAuth app
MICROSOFT_TENANT=consumers
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=

# Optional Supabase persistence. Use the service role only on the server.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional remote MCP servers can be passed per request by the frontend.
MCP_REQUIRE_APPROVAL=never
SCRAPE_TIMEOUT_MS=12000
